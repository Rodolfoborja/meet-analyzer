# ===========================================
# MeetAnalyzer - Environment Variables
# ===========================================

# PostgreSQL (URL externa - crear servicio en Dokploy)
DATABASE_URL=postgresql://user:password@postgres-service:5432/meetanalyzer

# JWT Secret (generar con: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-here

# URLs
FRONTEND_URL=https://meet.tudominio.com
BACKEND_URL=https://api-meet.tudominio.com

# Transcription (AssemblyAI)
ASSEMBLYAI_API_KEY=tu-api-key

# Email (Resend - opcional)
RESEND_API_KEY=
EMAIL_FROM=MeetAnalyzer <noreply@tudominio.com>

# Redis (interno Docker)
REDIS_URL=redis://redis:6379
