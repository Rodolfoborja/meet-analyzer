# ===========================================
# MeetAnalyzer - Environment Configuration
# ===========================================

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/meetanalyzer?schema=public"

# Redis (for job queues)
REDIS_URL="redis://localhost:6379"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"

# Google OAuth (for login + Calendar + Meet)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Microsoft OAuth (for Teams integration)
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""

# Transcription Service (AssemblyAI recommended)
ASSEMBLYAI_API_KEY=""

# Email Service (Resend)
RESEND_API_KEY=""
EMAIL_FROM="MeetAnalyzer <noreply@yourdomain.com>"

# Storage (S3-compatible - MinIO, AWS S3, etc.)
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="meetanalyzer"
S3_REGION="us-east-1"

# ===========================================
# User-configurable API Keys (stored in DB)
# ===========================================
# These are set per-user in the settings page:
# - OPENAI_API_KEY
# - ANTHROPIC_API_KEY  
# - GOOGLE_AI_API_KEY (Gemini)
