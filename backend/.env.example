# Backend Environment Variables

# Server
PORT=4000
NODE_ENV=development

# Database (PostgreSQL - URL externa de Dokploy)
DATABASE_URL=postgresql://user:password@postgres-host:5432/meetanalyzer

# JWT
JWT_SECRET=your-secret-key-here

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:3000

# Backend URL (para URLs de archivos)
BACKEND_URL=http://localhost:4000

# Transcription (AssemblyAI)
ASSEMBLYAI_API_KEY=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=MeetAnalyzer <noreply@tudominio.com>

# Redis (opcional - para jobs en background)
REDIS_URL=redis://localhost:6379
