# ===========================================
# MeetAnalyzer - Production Environment
# ===========================================

# Database (interno Docker)
DB_PASSWORD=your-secure-password-here

# App URL (tu dominio)
NEXTAUTH_URL=https://meet.tudominio.com
NEXTAUTH_SECRET=genera-con-openssl-rand-base64-32

# Transcription (AssemblyAI)
ASSEMBLYAI_API_KEY=tu-api-key

# Email (Resend - opcional)
RESEND_API_KEY=tu-api-key
EMAIL_FROM=MeetAnalyzer <noreply@tudominio.com>

# Google OAuth (opcional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# MinIO Storage (opcional)
MINIO_USER=admin
MINIO_PASSWORD=your-secure-password
